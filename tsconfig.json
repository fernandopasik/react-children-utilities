{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "inlineSources": true,
    "jsx": "react",
    "lib": ["dom", "dom.iterable", "es2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "target": "es2022",
    "types": ["node"]
  },
  "exclude": ["*.config.js", "**/*.flow", "coverage", "lib", "react-children-utilities.*"],
  "include": [".**/**/*", "**/*"]
}
